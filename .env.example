# ─── Payload CMS ──────────────────────────────────────────────────────────────
# Postgres connection string (Supabase pooler recommended).
# Find it at: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URI=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Secret used by Payload for authentication tokens. Change in production!
PAYLOAD_SECRET=your-payload-secret-change-in-production

# Public URL of the server (used for middleware redirect rule fetching)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000


# ─── Analytics (Cloudflare Web Analytics) ─────────────────────────────────────
# Your analytics token. Only loaded after the user accepts the cookie consent banner.
# Leave unset to disable analytics entirely.
NEXT_PUBLIC_GA4_ID=


# ─── Email (Resend) ───────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# Sender address verified with Resend (must match your verified domain)
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Your Company Name

# Destination address for incoming contact form inquiries
CONTACT_EMAIL=hello@yourdomain.com

# Public URL to the downloadable guide PDF (returned in guide sign-up emails)
GUIDE_PDF_URL=https://yourdomain.com/guides/your-guide.pdf


# ─── Database (Supabase) — optional ──────────────────────────────────────────
# Used to log guide sign-ups and contact form submissions.
# If not set, submissions are logged to the server console only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# ─── Staging auth — optional ─────────────────────────────────────────────────
# Set this to password-protect the site in staging/preview environments.
# Leave unset (or empty) to disable staging auth entirely.
STAGING_PASSWORD=


# ─── Stripe (plugin-stripe & plugin-ecommerce) ──────────────────────────────
# Stripe secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Stripe webhook endpoint secret for verifying webhook signatures
STRIPE_WEBHOOKS_ENDPOINT_SECRET=whsec_your-webhook-secret


# ─── S3 Storage (storage-s3) ─────────────────────────────────────────────────
# AWS S3 or S3-compatible storage for media uploads
S3_BUCKET=plenor-media
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key
S3_REGION=us-east-1
# Optional: custom S3 endpoint for S3-compatible services (e.g., Cloudflare R2, MinIO)
# S3_ENDPOINT=https://your-endpoint.r2.cloudflarestorage.com


# ─── UploadThing Storage (storage-uploadthing) ──────────────────────────────
# Token from https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=your-uploadthing-token


# ─── Sentry (plugin-sentry) ──────────────────────────────────────────────────
# Sentry DSN for error tracking. Leave unset to disable.
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
