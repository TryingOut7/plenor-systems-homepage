# ─── Payload CMS ──────────────────────────────────────────────────────────────
# Postgres connection string (Supabase pooler recommended).
# Find it at: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URI=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# When false, accepts self-signed/intermediate cert chains (common in local dev with poolers).
# Set true in production if your runtime trusts the full CA chain.
DATABASE_SSL_REJECT_UNAUTHORIZED=false
# Schema push is expensive in dev. Keep false for fast local page loads.
# Set true temporarily when you intentionally want Payload to push DB schema changes.
PAYLOAD_DB_PUSH=false

# Secret used by Payload for authentication tokens. Change in production!
PAYLOAD_SECRET=your-payload-secret-change-in-production
# Optional dedicated secret for the one-time local site-page seed command.
# If unset, the seed command falls back to PAYLOAD_SECRET.
PAYLOAD_SEED_SECRET=

# Public URL of the server (used for middleware redirect rule fetching)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Payload Admin Panel (optional) ──────────────────────────────────────────
# Root-level routes (keep defaults unless you also update app/(payload) route structure).
PAYLOAD_ROUTE_ADMIN=/admin
PAYLOAD_ROUTE_API=/api
PAYLOAD_ROUTE_GRAPHQL=/graphql
PAYLOAD_ROUTE_GRAPHQL_PLAYGROUND=/graphql-playground

# Admin-level routes (inside admin panel)
PAYLOAD_ADMIN_ROUTE_ACCOUNT=/account
PAYLOAD_ADMIN_ROUTE_BROWSE_BY_FOLDER=/browse-by-folder
PAYLOAD_ADMIN_ROUTE_CREATE_FIRST_USER=/create-first-user
PAYLOAD_ADMIN_ROUTE_FORGOT=/forgot
PAYLOAD_ADMIN_ROUTE_INACTIVITY=/logout-inactivity
PAYLOAD_ADMIN_ROUTE_LOGIN=/login
PAYLOAD_ADMIN_ROUTE_LOGOUT=/logout
PAYLOAD_ADMIN_ROUTE_RESET=/reset
PAYLOAD_ADMIN_ROUTE_UNAUTHORIZED=/unauthorized

# Theme + profile avatar
# PAYLOAD_ADMIN_THEME=all|light|dark
# PAYLOAD_ADMIN_AVATAR=default|gravatar
PAYLOAD_ADMIN_THEME=all
PAYLOAD_ADMIN_AUTO_REFRESH=true

# Auto-login for local demos only (ignored in production)
PAYLOAD_ADMIN_AUTO_LOGIN=false
PAYLOAD_ADMIN_AUTO_LOGIN_EMAIL=
PAYLOAD_ADMIN_AUTO_LOGIN_PASSWORD=
PAYLOAD_ADMIN_AUTO_LOGIN_USERNAME=
PAYLOAD_ADMIN_AUTO_LOGIN_PREFILL_ONLY=true

# Admin UX and metadata
PAYLOAD_ADMIN_DATE_FORMAT=MMM d, yyyy h:mm a
PAYLOAD_ADMIN_FALLBACK_LANGUAGE=en
PAYLOAD_ADMIN_META_TITLE_SUFFIX= | Plenor CMS
# PAYLOAD_ADMIN_META_DEFAULT_OG_IMAGE_TYPE=dynamic|off|static
PAYLOAD_ADMIN_META_DEFAULT_OG_IMAGE_TYPE=dynamic
PAYLOAD_ADMIN_SUPPRESS_HYDRATION_WARNING=false
PAYLOAD_ADMIN_PROJECT_NAME=Plenor Systems
PAYLOAD_ADMIN_ENV_LABEL=development
PAYLOAD_ADMIN_SHOW_ENV_BADGE=true

# Toast behavior
PAYLOAD_ADMIN_TOAST_DURATION_MS=5000
PAYLOAD_ADMIN_TOAST_LIMIT=5
PAYLOAD_ADMIN_TOAST_EXPAND=false
# PAYLOAD_ADMIN_TOAST_POSITION=bottom-right|bottom-left|bottom-center|top-right|top-left|top-center
PAYLOAD_ADMIN_TOAST_POSITION=bottom-right

# Timezone options for date fields with `timezone: true`
PAYLOAD_ADMIN_TIMEZONES=Europe/Zurich,America/New_York
PAYLOAD_ADMIN_DEFAULT_TIMEZONE=UTC
PAYLOAD_ADMIN_INCLUDE_UTC_TIMEZONE=true

# Optional plugin flags
# Set true only if you need hierarchical parent/child site-pages.
PAYLOAD_ENABLE_NESTED_DOCS=false


# ─── Analytics (Cloudflare Web Analytics) ─────────────────────────────────────
# Analytics token is managed via CMS (SiteSettings → analyticsId).
# No env var needed — set the token in the Payload admin panel instead.


# ─── Email (Resend) ───────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# Sender address verified with Resend (must match your verified domain)
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Your Company Name

# Destination address for incoming contact form inquiries
CONTACT_EMAIL=hello@yourdomain.com

# Public URL to the downloadable guide PDF (returned in guide sign-up emails)
GUIDE_PDF_URL=https://yourdomain.com/guides/your-guide.pdf


# ─── Database (Supabase) — optional ──────────────────────────────────────────
# Used to log guide sign-ups and contact form submissions.
# If not set, submissions are logged to the server console only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# ─── CRM webhook — optional ──────────────────────────────────────────────────
# If set, guide and inquiry form submissions are forwarded to an external CRM endpoint.
# Silently skipped if CRM_WEBHOOK_URL is not set.
CRM_WEBHOOK_URL=
# Optional shared secret sent as X-Webhook-Secret header for webhook authentication.
CRM_WEBHOOK_SECRET=


# ─── Workflow notifications — optional ───────────────────────────────────────
# Email address for workflow approval notifications. Defaults to RESEND_FROM_EMAIL.
WORKFLOW_NOTIFY_EMAIL=


# ─── CMS cache tuning — optional ─────────────────────────────────────────────
# Time-to-live for CMS data cache in milliseconds (default: 60000 = 60s).
CMS_CACHE_TTL_MS=60000
# Backoff duration after a CMS failure before retrying (default: 30000 = 30s).
CMS_FAILURE_BACKOFF_MS=30000


# ─── Redirect middleware in local dev — optional ─────────────────────────────
# By default, redirect rule fetching is disabled in development for faster local page loads.
# Set to true only if you need to test DB-driven redirect rules locally.
ENABLE_DEV_REDIRECT_RULES=false
