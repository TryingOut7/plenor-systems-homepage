# ─── Sanity CMS ───────────────────────────────────────────────────────────────
# Your Sanity project ID — found at https://sanity.io/manage under your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id

# The dataset to use. Defaults to "production" if not set.
NEXT_PUBLIC_SANITY_DATASET=production

# A Sanity API token with at least "Viewer" role.
# Used to fetch unpublished draft content in preview/draft mode.
# Generate one at: https://sanity.io/manage → your project → API → Tokens
SANITY_API_READ_TOKEN=your-sanity-read-token

# A random secret string used to authenticate preview mode activation.
# Set this same value in your Sanity project's "preview URL" configuration:
#   https://your-site.com/api/draft-mode/enable?secret=SANITY_PREVIEW_SECRET&redirect=/
# Generate with: openssl rand -hex 32
SANITY_PREVIEW_SECRET=your-random-preview-secret


# ─── Email (Resend) ───────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# Sender address verified with Resend (must match your verified domain)
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Your Company Name

# Destination address for incoming contact form inquiries
CONTACT_EMAIL=hello@yourdomain.com

# Public URL to the downloadable guide PDF (returned in guide sign-up emails)
GUIDE_PDF_URL=https://yourdomain.com/guides/your-guide.pdf


# ─── Database (Supabase) — optional ──────────────────────────────────────────
# Used to log guide sign-ups and contact form submissions.
# If not set, submissions are logged to the server console only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# ─── Staging auth — optional ─────────────────────────────────────────────────
# Set this to password-protect the site in staging/preview environments.
# Leave unset (or empty) to disable staging auth entirely.
STAGING_PASSWORD=
