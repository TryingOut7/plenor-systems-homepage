#!/usr/bin/env bash
# Pre-push hook: catches schema drift before it reaches production.
#
# Runs two checks:
#   1. Pending SQL migrations (migrations/versions/) — ensures nothing was
#      committed to the migration directory but not yet applied.
#   2. Payload generated-schema parity — verifies all expected Payload tables,
#      columns, and enum labels exist in the target DB.
#
# To install: npm run hooks:install
# To skip (emergency only): git push --no-verify

set -euo pipefail

# ── Resolve project root ─────────────────────────────────────────────────────
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# ── Load environment variables ───────────────────────────────────────────────
if [ -f ".env.local" ]; then
  set -a
  # shellcheck source=/dev/null
  source .env.local
  set +a
elif [ -f ".env" ]; then
  set -a
  # shellcheck source=/dev/null
  source .env
  set +a
fi

# ── Verify DB connectivity is available ─────────────────────────────────────
if [ -z "${POSTGRES_URL:-}" ] && [ -z "${DATABASE_URI:-}" ] && [ -z "${DATABASE_URL:-}" ]; then
  echo "⚠️  pre-push: POSTGRES_URL / DATABASE_URI / DATABASE_URL not set — skipping schema checks."
  echo "   Add one of those vars to .env.local to enable schema drift detection."
  exit 0
fi

echo "🔍 [pre-push] Checking for pending backend migrations..."
# Command substitution must not trip `set -e` when migrate-status exits non-zero.
set +e
migrate_status_output=$(node scripts/db/migrate-status.mjs --check 2>&1)
migrate_exit=$?
set -e
if echo "$migrate_status_output" | grep -qE "Missing POSTGRES_URL|Missing DATABASE_URI|Missing DATABASE_URL|Connection refused|ECONNREFUSED|connect ENOENT"; then
  echo "   ⚠️  DB unreachable locally — skipping pending migration check."
  echo "   CI will verify and apply migrations on deploy."
elif [ $migrate_exit -ne 0 ]; then
  echo "$migrate_status_output"
  echo ""
  echo "❌ [pre-push] Pending migrations found. Either:"
  echo "   • Run 'npm run db:migrate:backend' to apply them locally, OR"
  echo "   • Commit missing migration files before pushing."
  exit 1
else
  echo "   ✓ No pending migrations."
fi

echo ""
echo "🔍 [pre-push] Checking Payload generated-schema parity..."
if ! node scripts/db/check-payload-generated-schema-parity.mjs 2>&1; then
  echo ""
  echo "❌ [pre-push] Schema drift detected."
  echo "   Create/apply migrations, then run db:schema:ensure:check before pushing."
  exit 1
fi
echo "   ✓ Schema is up to date."

echo ""
echo "✅ [pre-push] All schema checks passed."
exit 0
