{
  "name": "plenor-systems-homepage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "check:runtime": "node scripts/check-runtime.mjs",
    "check:payload-importmap": "node scripts/check-payload-importmap.mjs",
    "predeploy:guardrails": "npm run check:runtime && npm run db:check:query-presets-enum-manifest && npm run db:schema:drift:check && npm run cms:schema:check && npm run check:payload-importmap && npm run check:type",
    "dev": "next dev --turbopack",
    "dev:schema-push": "PAYLOAD_DB_PUSH=true PAYLOAD_CONFIRM_SCHEMA_PUSH=true next dev --turbopack",
    "build": "npm run check:runtime && npm run check:payload-importmap && npm run db:check:query-presets-enum-manifest && npm run db:migrate:backend && npm run db:migrate:payload && npm run db:schema:drift:check && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:architecture": "eslint src/domain src/application src/app/api",
    "check:type": "tsc --noEmit --pretty false --project tsconfig.typecheck.json",
    "openapi:generate": "openapi-typescript apps/backend/openapi/openapi.yaml -o packages/api-client/src/generated.ts",
    "openapi:check": "npm run openapi:generate && git diff --exit-code -- packages/api-client/src/generated.ts",
    "db:migrate:backend": "node scripts/db/migrate.mjs && node scripts/db/sync-payload-locked-docs-rels.mjs",
    "db:check:query-presets-enum-manifest": "node scripts/db/check-query-presets-enum-manifest.mjs",
    "db:sync:payload-rels": "node scripts/db/sync-payload-locked-docs-rels.mjs",
    "db:migrate:backend:status": "node scripts/db/migrate-status.mjs",
    "db:migrate:rollback": "node scripts/db/migrate-rollback.mjs",
    "db:migrate:payload": "payload migrate",
    "db:migrate:payload:status": "payload migrate:status",
    "db:check:payload": "node scripts/db/check-payload-schema.mjs",
    "db:repair:payload": "node scripts/db/repair-payload-schema.mjs",
    "db:schema:drift": "node scripts/db/schema-drift.mjs",
    "db:schema:drift:check": "node scripts/db/schema-drift.mjs --check-only",
    "hooks:install": "bash scripts/install-git-hooks.sh",
    "test": "npm run test:ci",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:ci": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "backend:dev": "npm run dev --workspace @plenor/backend",
    "backend:start": "npm run start --workspace @plenor/backend",
    "backend:lint": "npm run lint --workspace @plenor/backend",
    "backend:typecheck": "npm run typecheck --workspace @plenor/backend",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:migration": "payload migrate:create",
    "seed:site-pages": "node scripts/seed-site-pages.mjs",
    "seed:forms": "node scripts/seed-forms.mjs",
    "migrate:legacy-sections": "node --import tsx scripts/migrate-legacy-sections.mjs --report=.tmp/legacy-migration-report.json",
    "migrate:legacy-sections:apply": "node --import tsx scripts/migrate-legacy-sections.mjs --apply --report=.tmp/legacy-migration-report.json",
    "migrate:legacy-sections:cutover-check": "node --import tsx scripts/check-legacy-cutover.mjs --report=.tmp/legacy-migration-report.json",
    "migrate:guide-inquiry-sections": "node --import tsx scripts/migrate-guide-inquiry-sections.mjs --report=.tmp/guide-inquiry-form-migration-report.json",
    "migrate:guide-inquiry-sections:apply": "node --import tsx scripts/migrate-guide-inquiry-sections.mjs --apply --report=.tmp/guide-inquiry-form-migration-report.json",
    "cms:audit:dashboard": "npx -y node@20 --import tsx scripts/generate-audit-dashboard.mjs",
    "cms:schema:check": "npx -y node@20 --import tsx scripts/check-cms-schema-governance.mjs",
    "backup": "bash scripts/backup.sh"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@payloadcms/db-postgres": "^3.79.1",
    "@payloadcms/email-resend": "^3.79.1",
    "@payloadcms/next": "^3.79.1",
    "@payloadcms/plugin-form-builder": "^3.79.1",
    "@payloadcms/plugin-import-export": "^3.79.1",
    "@payloadcms/plugin-nested-docs": "^3.79.1",
    "@payloadcms/plugin-search": "^3.79.1",
    "@payloadcms/plugin-seo": "^3.79.1",
    "@payloadcms/richtext-lexical": "^3.79.1",
    "@payloadcms/storage-vercel-blob": "^3.79.1",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/supabase-js": "^2.99.0",
    "@vercel/speed-insights": "^2.0.0",
    "next": "16.2.0",
    "payload": "^3.79.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "knip": "^6.3.0",
    "openapi-typescript": "^7.10.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
