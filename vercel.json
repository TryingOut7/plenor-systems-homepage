{
  "framework": "nextjs",
  "regions": ["iad1"],
  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/internal/cron/backup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/internal/cron/outbox-tick",
      "schedule": "0 0 * * *"
    }
  ]
}
